{
  "datasets": [
    {
      "name": "a1b2c3d4",
      "displayName": "Total Claims",
      "queryLines": [
        "SELECT SUM(total_claims) AS total_claims\n",
        "FROM healthcare.analytics.week2_dashboard_summary"
      ]
    },
    {
      "name": "b2c3d4e5",
      "displayName": "Claims Trend",
      "queryLines": [
        "SELECT\n",
        "  claim_date,\n",
        "  total_claims,\n",
        "  active_provider_count,\n",
        "  total_billed_amount,\n",
        "  avg_billed_amount,\n",
        "  high_cost_claim_count\n",
        "FROM healthcare.analytics.week2_dashboard_summary\n",
        "ORDER BY claim_date"
      ]
    },
    {
      "name": "c3d4e5f6",
      "displayName": "Claims By Specialty",
      "queryLines": [
        "SELECT\n",
        "  specialty,\n",
        "  claim_count,\n",
        "  provider_count,\n",
        "  avg_billed_amount,\n",
        "  total_billed_amount\n",
        "FROM healthcare.analytics.claims_by_specialty_summary\n",
        "ORDER BY claim_count DESC, specialty ASC"
      ]
    },
    {
      "name": "d4e5f6a7",
      "displayName": "Claims By Region",
      "queryLines": [
        "SELECT\n",
        "  region,\n",
        "  claim_count,\n",
        "  provider_count,\n",
        "  avg_billed_amount,\n",
        "  total_billed_amount\n",
        "FROM healthcare.analytics.claims_by_region_summary\n",
        "ORDER BY claim_count DESC, region ASC"
      ]
    },
    {
      "name": "e5f6a7b8",
      "displayName": "High Cost Claims",
      "queryLines": [
        "SELECT\n",
        "  claim_id,\n",
        "  provider_id,\n",
        "  doctor_name,\n",
        "  specialty,\n",
        "  region,\n",
        "  procedure_code,\n",
        "  billed_amount,\n",
        "  expected_cost,\n",
        "  amount_to_benchmark_ratio\n",
        "FROM healthcare.analytics.high_cost_claims_summary\n",
        "ORDER BY amount_to_benchmark_ratio DESC, claim_id ASC"
      ]
    },
    {
      "name": "f6a7b8c9",
      "displayName": "Pipeline Updates",
      "queryLines": [
        "SELECT\n",
        "  timestamp,\n",
        "  update_id,\n",
        "  pipeline_id,\n",
        "  update_state,\n",
        "  actor\n",
        "FROM healthcare.analytics.ops_pipeline_updates\n",
        "ORDER BY timestamp DESC"
      ]
    },
    {
      "name": "a7b8c9d0",
      "displayName": "Expectation Metrics",
      "queryLines": [
        "SELECT\n",
        "  timestamp,\n",
        "  update_id,\n",
        "  dataset,\n",
        "  expectation,\n",
        "  passed_records,\n",
        "  failed_records\n",
        "FROM healthcare.analytics.ops_expectation_metrics\n",
        "ORDER BY timestamp DESC"
      ]
    },
    {
      "name": "b8c9d0e1",
      "displayName": "Latest Failures",
      "queryLines": [
        "SELECT\n",
        "  timestamp,\n",
        "  dataset,\n",
        "  update_id,\n",
        "  platform_error_code,\n",
        "  diagnostic_id,\n",
        "  error_message\n",
        "FROM healthcare.analytics.ops_latest_failures\n",
        "ORDER BY timestamp DESC"
      ]
    }
  ],
